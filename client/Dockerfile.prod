# build stage 
FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm install --legacy-peer-deps

COPY . .

# Vite reads VITE_* env at build time. If VITE_OWNER_NAME needs to be
# baked in, pass it via docker-compose args (see note below).
ARG VITE_OWNER_NAME
ENV VITE_OWNER_NAME=$VITE_OWNER_NAME

RUN npm run build

# serve stage 
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80